# Keep the build context small and the image clean. The Dockerfile only needs
# pyproject.toml, README.md, LICENSE, and the facekeep/ package — everything else
# is excluded. (README + LICENSE are intentionally NOT ignored: pyproject reads
# README for the long description and LICENSE completes the wheel.)

# Virtualenvs (never copy a host venv into the image)
.venv/
.venv-mediapipe/
.venv-pkgtest/
venv/

# Python build / cache artifacts
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.eggs/
build/
dist/

# Tests, docs, benchmarks, examples — not needed at runtime
tests/
docs/
_bench/
examples/

# VCS / CI / tooling
.git/
.github/
.gitignore
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# Local external binaries (machine-local; offline-first default ships without)
.tools/

# Docker's own files (no need inside the context)
Dockerfile
.dockerignore

# Claude Code local settings
.claude/

# FaceKeep outputs / caches that may litter the working tree
*.fkeep
*.avif
*.jxl
*.webp
compressed/
outputs/
test_run/

# Models / weights (fetched at runtime into the cache, never baked in)
*.onnx
*.pth

# Reproducible sample image (regenerate with examples/make_sample.py)
examples/sample_family.jpg

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/
